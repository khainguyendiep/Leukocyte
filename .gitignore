# ─── Editor and IDE artifacts ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# Generated during compile stage — recreated by make, never committed
*.o
.submodule_ready

# ─── Executable files (tool binaries) ─────────────────────────────────────────
# Leading slash anchors the pattern to project root only — prevents matching
# tools/anti_DOS/ directory or any other subdirectory with the same name
/anti_DOS
/port_scan_detector
/brute_force
